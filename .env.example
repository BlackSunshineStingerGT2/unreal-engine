# YouTube Pipeline Configuration
# Copy to .env and fill in values

# PostgreSQL (Railway)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/railway

# YouTube Data API v3
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY

# Anthropic API (Unreal Engine brain)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

# Pipeline Settings
POLLING_INTERVAL_MINUTES=30
ENGAGEMENT_SNAPSHOT_HOURS=1,6,24,72
MAX_COMMENTS_PER_VIDEO=500
TRANSCRIPT_LANGUAGE=en

# Auth
PIPELINE_TOKEN=YOUR_SECRET_TOKEN

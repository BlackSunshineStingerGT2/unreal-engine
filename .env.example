# YouTube Pipeline Configuration
# Copy to .env and fill in values

# PostgreSQL (Railway)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT/railway

# YouTube Data API v3
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY

# Anthropic API (Unreal Engine brain)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

# Pipeline Settings
POLLING_INTERVAL_MINUTES=30
ENGAGEMENT_SNAPSHOT_HOURS=1,6,24,72
MAX_COMMENTS_PER_VIDEO=500
TRANSCRIPT_LANGUAGE=en

# Reddit API (application-only auth — create at reddit.com/prefs/apps)
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET
REDDIT_USER_AGENT=UnrealEngine/1.0 (UAP Intelligence Pipeline)
REDDIT_POLLING_INTERVAL_MINUTES=15

# Auth
PIPELINE_TOKEN=YOUR_SECRET_TOKEN
